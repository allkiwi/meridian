# Database
DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian

# JWT — generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# App
DEBUG=false
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# Google OAuth — used for login/registration and future Gmail integration
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Add Authorized Redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (for AI features in later phases)
ANTHROPIC_API_KEY=sk-ant-...
